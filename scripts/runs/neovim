#!/usr/bin/env bash

set -e # Exit if any command fails.

# Usage:
#   ./runs/neovim             Install (or reinstall) tmux.
#   ./runs/neovim --dry       Show what would be executed, without doing it.
#   ./runs/neovim --uninstall Remove tmux.

script_dir="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"

dry_run="0"
uninstall="0"

while [[ $# -gt 0 ]]; do
    echo "ARG: \"$1\""
    if [[ "$1" == "--dry" ]]; then
        dry_run="1"
    fi
    if [[ "$1" == "--uninstall" ]]; then
        uninstall="1"
    fi
    shift
done

log() {
    if [[ $dry_run == "1" ]]; then
        echo "[DRY_RUN] $@"
    else
        echo "[DEBUG] $@"
    fi
}

execute() {
    log "execute $@"
    if [[ $dry_run == "1" ]]; then
        return
    fi
    "$@"
}

create_dir() {
    if [ -d "$@" ]; then
        log The "$@" folder already exists
    else
        log The "$@" folder does not exists. Creating
        execute mkdir -p "$@"
    fi
}

install_from_source() {
    # https://github.com/neovim/neovim/blob/master/BUILD.md#build-prerequisites
    execute pushd /tmp > /dev/null
    execute git clone --depth 1 --branch stable https://github.com/neovim/neovim
    execute cd neovim
    execute gmake CMAKE_BUILD_TYPE=Release
    case $(uname) in
      *BSD*)
        execute sudo gmake install
        ;;
      *)
        execute sudo make install
        ;;
    esac
    execute popd > /dev/null
}

install_nerd_fonts() {
    # https://www.youtube.com/watch?v=mQdB_kHyZn8
    FONT=JetBrainsMono
    FONTS_FILE=$FONT.tar.xz
    execute pushd /tmp > /dev/null
    case $(uname) in
      Darwin)
        FONTS_PATH=$HOME/Library/Fonts/
        ;;
      *)
        FONTS_PATH=$HOME/.local/share/fonts
        ;;
    esac
    if [ ! -f $FONTS_FILE ]; then
        execute curl -fLO https://github.com/ryanoasis/nerd-fonts/releases/download/v3.4.0/$FONTS_FILE
    fi
    if [ ! -d $FONTS_PATH ]; then
        execute mkdir $FONTS_PATH
    fi
    execute tar -xvf $FONTS_FILE --directory $FONTS_PATH
    execute popd > /dev/null
    log Showing that the new fonts are available:
    case $(uname) in
      Darwin)
        # fc-list (fontconfig) is not available on macOS by default.
        execute ls "$FONTS_PATH" | grep $FONT
        ;;
      *)
        execute fc-list | grep $FONT
        ;;
    esac
    # Configure the xfce4-terminal fonts family, to avoid incorrect icons in nvim-tree.
    # Terminal menu: Edit > Preferences > Appearance > Font.
    # There, uncheck `Use system font` and select `JetBrainsMono Nerd Font Regular`.
    # If the fonts family does not appear, close and open the terminal and repeat the menu clicks.
    # To use a font without ligature (combines characters like `!=`, `==` into one), use
    # a font that contains NL in its name, example: JetBrainsMonoNL Nerd Font Regular.
}

install_vim_plug() {
    # https://github.com/junegunn/vim-plug?tab=readme-ov-file#neovim
    execute sh -c 'curl -fLo "${XDG_DATA_HOME:-$HOME/.local/share}"/nvim/site/autoload/plug.vim --create-dirs https://raw.githubusercontent.com/junegunn/vim-plug/master/plug.vim'
    # To run the following command the vim_plug must be configured in the config file in ~/.config/nvim/
    execute nvim -c 'PlugInstall'
    log Some manual steps are required. Open neovim and execute \`:PlugInstall\`. Press Enter to continue when done
    execute read -p "" </dev/tty
}

nvim_darwin_paths() {
    opt_path="$HOME/.local/opt"
    install_path="$HOME/.local/bin"
    bin_name="nvim"

    case $(uname -m) in
      arm64|aarch64)
        arch="arm64"
        ;;
      x86_64|amd64)
        arch="x86_64"
        ;;
      *)
        echo "[ERROR] Unsupported architecture: $(uname -m)"
        exit 1
        ;;
    esac

    dir_name="nvim-macos-${arch}"
}

backup_nvim_darwin() {
    if [ -d "$opt_path/$dir_name" ]; then
        backup_dir="$opt_path/$dir_name.bak.$(date +%Y%m%d%H%M%S)"
        log "Backing up current $dir_name to $backup_dir"
        execute cp -pR "$opt_path/$dir_name" "$backup_dir"
    else
        log "No existing $dir_name folder found at $opt_path, skipping backup"
    fi
}

uninstall_nvim_darwin() {
    nvim_darwin_paths
    backup_nvim_darwin

    if [ -d "$opt_path/$dir_name" ]; then
        execute rm -rf "$opt_path/$dir_name"
    else
        log "$dir_name is not installed at $opt_path"
    fi

    if [ -e "$install_path/$bin_name" ] || [ -L "$install_path/$bin_name" ]; then
        execute rm -f "$install_path/$bin_name"
    else
        log "$bin_name is not installed at $install_path"
    fi
}

install_nvim_darwin() {
    # Pinned to a fixed release (not "latest") for security/reproducibility.
    # https://github.com/neovim/neovim/releases/tag/v0.12.4
    nvim_darwin_paths

    tag="v0.12.4"
    asset="${dir_name}.tar.gz"
    url="https://github.com/neovim/neovim/releases/download/${tag}/${asset}"

    backup_nvim_darwin

    execute pushd /tmp > /dev/null
    execute curl -fL "$url" -o "$asset"
    execute mkdir -p "$opt_path"
    execute rm -rf "${opt_path:?}/${dir_name}"
    execute tar -xzf "$asset" -C "$opt_path"
    # curl (unlike Safari/Finder) does not set com.apple.quarantine, so this
    # should normally be a no-op. If it IS present, ask the user to remove it
    # manually rather than running xattr from the script.
    if [[ $dry_run != "1" ]] && xattr -p com.apple.quarantine "$opt_path/$dir_name" >/dev/null 2>&1; then
        log "The extracted files are quarantined. Please run manually:"
        log "    xattr -dr com.apple.quarantine \"$opt_path/$dir_name\""
        log "Press Enter to continue when done"
        execute read -p "" </dev/tty
    fi
    execute rm -f "$asset"
    execute popd > /dev/null

    execute mkdir -p "$install_path"
    execute ln -sf "$opt_path/$dir_name/bin/$bin_name" "$install_path/$bin_name"

    execute "$install_path/$bin_name" --version
}


if [[ $uninstall == "1" ]]; then
    case $(uname) in
      Darwin)
        uninstall_nvim_darwin
        ;;
      *)
        echo "[ERROR] --uninstall is not supported on this OS"
        exit 1
        ;;
    esac
    exit 0
fi

case $(uname) in
  *BSD*)
    # https://github.com/neovim/neovim/blob/master/BUILD.md#freebsd
    execute sudo pkg install -y cmake gmake gettext
    install_command=pkg
    ;;
  Darwin)
    ;;
  *)
    # https://github.com/neovim/neovim/blob/master/BUILD.md#ubuntu--debian
    execute sudo apt install -y ninja-build gettext cmake build-essential
    install_command=apt
    ;;
esac

case $(uname) in
  Darwin)
    execute "$script_dir/ripgrep" # Required by telescope.
    install_nvim_darwin
    install_vim_plug
    install_nerd_fonts
    ;;
  *)
    execute sudo $install_command install -y curl git
    # https://github.com/BurntSushi/ripgrep?tab=readme-ov-file#installation
    execute sudo $install_command install -y ripgrep # Required by telescope.
    execute sudo $install_command install -y xclip # To use clipboard.
    install_from_source
    install_vim_plug
    install_nerd_fonts
    ;;
esac
