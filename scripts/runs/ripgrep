#!/usr/bin/env bash

set -e # Exit if any command fails.

# Usage:
#   ./runs/ripgrep             Install.
#   ./runs/ripgrep --dry       Show what would be executed, without doing it.
#   ./runs/ripgrep --uninstall Remove.

dry_run="0"
uninstall="0"
install_path="$HOME/.local/bin"
downloads_path="$HOME/.cache/dotfiles/downloads"
bin_name="rg"
# Fixed release (not "latest") for security/reproducibility.
# https://github.com/BurntSushi/ripgrep/releases/tag/15.1.0
rg_tag="15.1.0"

while [[ $# -gt 0 ]]; do
    echo "ARG: \"$1\""
    if [[ "$1" == "--dry" ]]; then
        dry_run="1"
    fi
    if [[ "$1" == "--uninstall" ]]; then
        uninstall="1"
    fi
    shift
done

log() {
    if [[ $dry_run == "1" ]]; then
        echo "[DRY_RUN] $@"
    else
        echo "[DEBUG] $@"
    fi
}

execute() {
    log "execute $@"
    if [[ $dry_run == "1" ]]; then
        return
    fi
    "$@"
}

create_dir() {
    if [ -d "$@" ]; then
        log The "$@" folder already exists
    else
        log The "$@" folder does not exists. Creating
        execute mkdir -p "$@"
    fi
}

uninstall_darwin() {
    if [ -f "$install_path/$bin_name" ]; then
        execute rm -f "$install_path/$bin_name"
    else
        log "$bin_name is not installed at $install_path"
    fi
}

set_ripgrep_darwin_config() {
    case $(uname -m) in
      arm64|aarch64)
        arch="aarch64"
        ;;
      x86_64|amd64)
        arch="x86_64"
        ;;
      *)
        echo "[ERROR] Unsupported architecture: $(uname -m)"
        exit 1
        ;;
    esac

    dir_name="ripgrep-${rg_tag}-${arch}-apple-darwin"
    asset="${dir_name}.tar.gz"
    # Cache filename includes the tag so different pinned versions never
    # collide or get reused by mistake.
    cached_asset_path="$downloads_path/${asset}"
}

get_installed_ripgrep_version() {
    "$install_path/$bin_name" --version 2>/dev/null | head -n 1 | awk '{print $2}'
}

is_ripgrep_darwin_installed() {
    if [ ! -x "$install_path/$bin_name" ]; then
        return 1
    fi

    local installed_version
    installed_version="$(get_installed_ripgrep_version)"
    [[ "$installed_version" == "$rg_tag" ]]
}

download_ripgrep_darwin() {
    if [ -s "$cached_asset_path" ]; then
        log "Found cached $cached_asset_path, skipping download"
        return
    fi
    log "No valid cached download found at $cached_asset_path, downloading"
    create_dir "$downloads_path"
    url="https://github.com/BurntSushi/ripgrep/releases/download/${rg_tag}/${asset}"
    execute curl -fL "$url" -o "$cached_asset_path"
}

install_darwin() {
    set_ripgrep_darwin_config

    if is_ripgrep_darwin_installed; then
        log "$bin_name $rg_tag is already installed at $install_path, skipping install"
        return 0
    fi

    download_ripgrep_darwin

    uninstall_darwin

    execute pushd /tmp > /dev/null
    execute tar -xzf "$cached_asset_path" "${dir_name}/${bin_name}"
    execute mkdir -p "$install_path"
    execute mv "${dir_name}/${bin_name}" "$install_path/$bin_name"
    execute chmod +x "$install_path/$bin_name"
    execute rm -rf "$dir_name"
    execute popd > /dev/null
}

verify_installation() {
    # $1: explicit path to the rg binary to check, e.g. ~/.local/bin/rg.
    local rg_bin="$1"

    if [[ $dry_run == "1" ]]; then
        log "Skipping installation verification"
        return
    fi

    if [ ! -x "$rg_bin" ]; then
        echo "[ERROR] rg binary not found or not executable at $rg_bin"
        exit 1
    fi

    if ! "$rg_bin" --version >/dev/null 2>&1; then
        echo "[ERROR] $rg_bin --version failed after installation"
        exit 1
    fi

    installed_version="$(get_installed_ripgrep_version)"
    if [[ ! "$installed_version" == "$rg_tag" ]]; then
        echo "[ERROR] $rg_bin --version failed after installation"
        return 1
    fi

    log "Installation verified (rg): $installed_version"
}

case $(uname) in
  Darwin)
    if [[ $uninstall == "1" ]]; then
        uninstall_darwin
    else
        install_darwin
        verify_installation "$install_path/$bin_name"
    fi
    ;;
  *)
    echo "[ERROR] Not implemented for $(uname)"
    exit 1
    ;;
esac
