#!/usr/bin/env bash

set -e # Exit if any command fails.

# Usage:
#   ./runs/tmux             Install.
#   ./runs/tmux --dry       Show what would be executed, without doing it.
#   ./runs/tmux --uninstall Remove.

dry_run="0"
uninstall="0"
install_path="$HOME/.local/bin"
downloads_path="$HOME/.cache/dotfiles/downloads"
bin_name="tmux"

while [[ $# -gt 0 ]]; do
    echo "ARG: \"$1\""
    if [[ "$1" == "--dry" ]]; then
        dry_run="1"
    fi
    if [[ "$1" == "--uninstall" ]]; then
        uninstall="1"
    fi
    shift
done

log() {
    if [[ $dry_run == "1" ]]; then
        echo "[DRY_RUN] $@"
    else
        echo "[DEBUG] $@"
    fi
}

execute() {
    log "execute $@"
    if [[ $dry_run == "1" ]]; then
        return
    fi
    "$@"
}

create_dir() {
    if [ -d "$@" ]; then
        log The "$@" folder already exists
    else
        log The "$@" folder does not exists. Creating
        execute mkdir -p "$@"
    fi
}

uninstall_darwin() {
    if [ -f "$install_path/$bin_name" ]; then
        execute rm -f "$install_path/$bin_name"
    else
        log "$bin_name is not installed at $install_path"
    fi
}

set_tmux_darwin_config() {
    case $(uname -m) in
      arm64|aarch64)
        arch="arm64"
        ;;
      x86_64|amd64)
        arch="x86_64"
        ;;
      *)
        echo "[ERROR] Unsupported architecture: $(uname -m)"
        exit 1
        ;;
    esac

    # Pinned to a fixed release (not "latest") for security/reproducibility.
    # https://github.com/tmux/tmux-builds/releases/tag/v3.7b
    tmux_tag="v3.7b"
    version="${tmux_tag#v}"
    asset="tmux-${version}-macos-${arch}.tar.gz"
    # Cache filename includes the tag so different pinned versions never
    # collide or get reused by mistake.
    cached_asset_path="$downloads_path/${asset}"
}

get_installed_tmux_version() {
    # $1: path to (or name of) the tmux binary to query.
    "$1" -V 2>/dev/null | awk '{print $2}'
}

is_tmux_darwin_installed() {
    if [ ! -x "$install_path/$bin_name" ]; then
        return 1
    fi

    local installed_version
    installed_version="$(get_installed_tmux_version "$install_path/$bin_name")"
    [[ "$installed_version" == "$version" ]]
}

download_tmux_darwin() {
    if [ -s "$cached_asset_path" ]; then
        log "Found cached $cached_asset_path, skipping download"
        return
    fi
    log "No valid cached download found at $cached_asset_path, downloading"
    create_dir "$downloads_path"
    url="https://github.com/tmux/tmux-builds/releases/download/${tmux_tag}/${asset}"
    execute curl -fL "$url" -o "$cached_asset_path"
}

install_darwin() {
    set_tmux_darwin_config

    if is_tmux_darwin_installed; then
        log "$bin_name $version is already installed at $install_path, skipping install"
        return 0
    fi

    download_tmux_darwin

    uninstall_darwin

    execute pushd /tmp > /dev/null
    execute tar -xzf "$cached_asset_path" tmux
    execute mkdir -p "$install_path"
    execute mv tmux "$install_path/$bin_name"
    execute chmod +x "$install_path/$bin_name"
    execute popd > /dev/null
}

verify_installation() {
    # $1 (optional): explicit path to the tmux binary to check, e.g. ~/.local/bin/tmux.
    # If not given, resolve tmux from PATH instead.
    local tmux_bin="${1:-tmux}"

    if [[ $dry_run == "1" ]]; then
        log "Skipping installation verification"
        return
    fi

    if [ -n "$1" ]; then
        if [ ! -x "$tmux_bin" ]; then
            echo "[ERROR] tmux binary not found or not executable at $tmux_bin"
            exit 1
        fi
    elif ! command -v tmux >/dev/null 2>&1; then
        echo "[ERROR] tmux was not found on PATH after installation"
        exit 1
    fi

    installed_version="$(get_installed_tmux_version "$tmux_bin")"
    if [ -z "$installed_version" ]; then
        echo "[ERROR] $tmux_bin -V failed after installation"
        exit 1
    fi

    # $version is only set when installed via install_darwin (pinned release).
    # Package-manager installs (BSD/apt) have no pinned version to compare against.
    if [ -n "$version" ] && [[ "$installed_version" != "$version" ]]; then
        echo "[ERROR] $tmux_bin -V failed after installation"
        return 1
    fi

    log "Installation verified (tmux): $installed_version"
}

case $(uname) in
  Darwin)
    if [[ $uninstall == "1" ]]; then
        uninstall_darwin
    else
        install_darwin
        verify_installation "$install_path/$bin_name"
    fi
    ;;
  *BSD*)
    if [[ $uninstall == "1" ]]; then
        echo "[ERROR] --uninstall is not supported on this OS"
        exit 1
    fi
    execute sudo pkg install -y tmux
    verify_installation
    ;;
  *)
    if [[ $uninstall == "1" ]]; then
        echo "[ERROR] --uninstall is not supported on this OS"
        exit 1
    fi
    execute sudo apt install -y tmux
    verify_installation
    ;;
esac
