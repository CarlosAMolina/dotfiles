#!/usr/bin/env bash

set -e # Exit if any command fails.

# Usage:
#   ./runs/uv             Install.
#   ./runs/uv --dry       Show what would be executed, without doing it.
#   ./runs/uv --uninstall Remove.

dry_run="0"
uninstall="0"
install_path="$HOME/.local/bin"
downloads_path="$HOME/.cache/dotfiles/downloads"
bin_names=(uv uvx)

while [[ $# -gt 0 ]]; do
    echo "ARG: \"$1\""
    if [[ "$1" == "--dry" ]]; then
        dry_run="1"
    fi
    if [[ "$1" == "--uninstall" ]]; then
        uninstall="1"
    fi
    shift
done

log() {
    if [[ $dry_run == "1" ]]; then
        echo "[DRY_RUN] $@"
    else
        echo "[DEBUG] $@"
    fi
}

execute() {
    log "execute $@"
    if [[ $dry_run == "1" ]]; then
        return
    fi
    "$@"
}

create_dir() {
    if [ -d "$@" ]; then
        log The "$@" folder already exists
    else
        log The "$@" folder does not exists. Creating
        execute mkdir -p "$@"
    fi
}

uninstall_darwin() {
    for bin_name in "${bin_names[@]}"; do
        if [ -f "$install_path/$bin_name" ]; then
            execute rm -f "$install_path/$bin_name"
        else
            log "$bin_name is not installed at $install_path"
        fi
    done
}

set_uv_darwin_config() {
    # Pinned to a fixed release (not "latest") for security/reproducibility.
    # https://github.com/astral-sh/uv/releases/tag/0.11.29
    version="0.11.29"
    asset="uv-installer-${version}.sh"
    url="https://astral.sh/uv/${version}/install.sh"
    # Cache filename includes the version so different pinned releases never
    # collide or get reused by mistake.
    cached_asset_path="$downloads_path/${asset}"
}

get_installed_uv_version() {
    "$install_path/uv" --version 2>/dev/null | awk '{print $2}'
}

is_uv_darwin_installed() {
    for bin_name in "${bin_names[@]}"; do
        if [ ! -x "$install_path/$bin_name" ]; then
            return 1
        fi
    done

    local installed_version
    installed_version="$(get_installed_uv_version)"
    [[ "$installed_version" == "$version" ]]
}

download_uv_darwin() {
    if [ -s "$cached_asset_path" ]; then
        log "Found cached $cached_asset_path, skipping download"
        return
    fi
    log "No valid cached download found at $cached_asset_path, downloading"
    create_dir "$downloads_path"
    execute curl -LsSf "$url" -o "$cached_asset_path"
}

install_darwin() {
    set_uv_darwin_config

    if is_uv_darwin_installed; then
        log "uv $version is already installed at $install_path, skipping install"
        return 0
    fi

    download_uv_darwin

    uninstall_darwin

    # UV_INSTALL_DIR: install into ~/.local/bin (the default, made explicit here).
    # UV_NO_MODIFY_PATH: dotfiles already add ~/.local/bin to PATH, so don't let
    # the installer touch shell profiles.
    execute env UV_INSTALL_DIR="$install_path" UV_NO_MODIFY_PATH=1 sh "$cached_asset_path"
}

verify_installation() {
    if [[ $dry_run == "1" ]]; then
        log "Skipping installation verification"
        return
    fi

    for bin_name in "${bin_names[@]}"; do
        if [ ! -x "$install_path/$bin_name" ]; then
            echo "[ERROR] $bin_name binary not found or not executable at $install_path/$bin_name"
            exit 1
        fi
    done

    installed_version="$(get_installed_uv_version)"
    if [ -z "$installed_version" ]; then
        echo "[ERROR] $install_path/uv --version failed after installation"
        exit 1
    fi
    if [[ "$installed_version" != "$version" ]]; then
        echo "[ERROR] $install_path/uv --version failed after installation"
        exit 1
    fi
    log "Installation verified (uv): $installed_version"

    # Sanity check: the installer receipt should record the same install_prefix
    # we asked for, so future "uv self update" runs keep reinstalling here.
    receipt="$HOME/.config/uv/uv-receipt.json"
    if [ -f "$receipt" ]; then
        receipt_prefix=$(jq -r '.install_prefix' "$receipt")
        if [ "$receipt_prefix" != "$install_path" ]; then
            echo "[ERROR] uv-receipt.json install_prefix ($receipt_prefix) does not match expected $install_path"
            exit 1
        fi
        log "uv-receipt.json install_prefix matches $install_path"
    else
        echo "[ERROR] Expected receipt file not found at $receipt"
        exit 1
    fi
}

case $(uname) in
  Darwin)
    if [[ $uninstall == "1" ]]; then
        uninstall_darwin
    else
        install_darwin
        verify_installation
    fi
    ;;
  *)
    log "uv is not supported on $(uname), skipping"
    exit 0
    ;;
esac
